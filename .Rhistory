I <- 3
J <- 5
N <- array(0, dim = c(6, 3, 5))
## Function to apply to each sequence:
make_counts <- function(seq, N_group){
for(x in 2:length(seq)){
row.ref <- seq[x - 1]
col.ref <- seq[x]
N_group[row.ref, col.ref] <- N_group[row.ref, col.ref] + 1
}
return(N_group)
}
