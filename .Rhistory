## Matts way:
mse_AMC <- apply(theta, 1, function(x) K * sum((x - P[1,])^2) / (K*J) ) # multiply by K because we are evaluating it as a K by J matrix (where in AMC, each of the K rows uses the pooled estimate)
hist(mse_AMC, freq = FALSE)
mse_HAMC <- sapply(1:B, function(b) sum((hamc_res$theta[b,,] - P)^2) / (K*J) )
dim(hamc_res$theta[b,,])
dim(hamc_res$theta)
mse_HAMC <- sapply(1:B, function(b) sum((hamc_res$theta[b,,1,] - P)^2) / (K*J) )
par(mfrow = c(2,1))
xlim_use <- c(0, 0.006)
hist(mse_AMC, freq = FALSE, xlim = xlim_use, breaks = 30)
hist(mse_HAMC, freq = FALSE, xlim = xlim_use, breaks = 20)
mean(mse_AMC)
mean(mse_HAMC)
p <- c(50, 25, 20, 15, 10, 5, 3, 1, 0)
(p <- p / sum(p))
(J <- length(p)) # categories
I <- 1 # froms (in count matrix)
K <- 5 # groups
nk <- rep(100, K)
Y <- matrix(NA, nrow = K, ncol = J)
for (k in 1:K) {
Y[k,] <- tabulate(sample.int(J, size = nk[k], replace = TRUE, prob = p), nbins = J)
}
Y
Y / rep(rowSums(Y), times = J)
colSums(Y) / sum(Y)
## "AMC"
(xsi <- rep(1.0/J, J))
B <- 20e3 # MC samples
sim_AMC <- LaplacesDemon::rdirichlet(B, xsi + colSums(Y))
round(colMeans(sim_AMC), 4)
mse_AMC <- apply(sim_AMC, 1, function(x) K * sum((x - p)^2) / (K*J) ) # multiply by K because we are evaluating it as a K by J matrix (where in AMC, each of the K rows uses the pooled estimate)
hist(mse_AMC, freq = FALSE)
