## Function to run the proportional likelihood of one group given a row of counts,
partial_lik <- function(n, n_old, alpha,
gamma){
res <- sum(lgamma(n + gamma*alpha)) - lgamma(sum(n) + gamma)
res_old <- sum(lgamma(n_old + gamma*alpha)) - lgamma(sum(n_old) + gamma)
m <- max(res, res_old)
m + log(exp(res - m) - exp(res_old - m))
}
